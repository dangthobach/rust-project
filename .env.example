# Copy to `.env` next to `docker-compose.yml` (repo root). Run: `docker compose up -d` from that root, not from `scripts/`.
# On-premise PostgreSQL (same machine as Docker): use host.docker.internal
DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/DATABASE_NAME

JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-characters

# Optional: only if you start bundled Postgres with:
#   docker compose --profile local-postgres up -d postgres
# DATABASE_URL=postgresql://crm_app:crm_app@postgres:5432/crm
