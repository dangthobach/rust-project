# Neo CRM Backend - Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL 17 connection URL (sqlx + migrations in backend/migrations)
# Example local: postgresql://crm_app:crm_app@127.0.0.1:5432/crm
# Optional: integration tests / app_state test use TEST_DATABASE_URL the same way
DATABASE_URL=postgresql://crm_app:crm_app@127.0.0.1:5432/crm
# TEST_DATABASE_URL=postgresql://crm_app:crm_app@127.0.0.1:5432/crm_test

# ============================================================================
# JWT AUTHENTICATION (REQUIRED)
# ============================================================================
# Secret key for signing JWT tokens
# IMPORTANT: Generate a secure random string for production (min 32 characters)
#
# Generate with:
#   openssl rand -hex 32
#   OR python3 -c "import secrets; print(secrets.token_hex(32))"
#   OR node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# NEVER commit your actual JWT_SECRET to version control!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-characters

# JWT access token expiration time in seconds
# Default: 86400 (24 hours)
# Options: 3600 (1 hour), 86400 (24 hours), 604800 (7 days)
JWT_EXPIRATION=86400

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Host address to bind the server
# Default: 0.0.0.0 (all interfaces)
# Options: 0.0.0.0 (all), 127.0.0.1 (localhost only)
HOST=0.0.0.0

# Port number for the API server
# Default: 3000
PORT=3000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed CORS origin (frontend URL)
# Default: http://localhost:5173
# IMPORTANT: Set to your actual frontend domain in production
# Examples:
#   Development: http://localhost:5173
#   Production: https://crm.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# Maximum file size in bytes
# Default: 10485760 (10MB)
# Examples:
#   5MB = 5242880
#   10MB = 10485760
#   50MB = 52428800
MAX_FILE_SIZE=10485760

# Directory for storing uploaded files
# Default: ./uploads
# IMPORTANT: Ensure this directory exists and has write permissions
UPLOAD_DIR=./uploads

# ============================================================================
# REDIS CONFIGURATION (Required for CQRS Event Bus)
# ============================================================================
# Redis connection URL
# Default: redis://127.0.0.1:6379
# Format: redis://[username:password@]host[:port][/database]
#
# Examples:
#   Local: redis://127.0.0.1:6379
#   Docker: redis://redis:6379
#   Auth: redis://:password@127.0.0.1:6379
#   Database: redis://127.0.0.1:6379/0
#
# NOTE: Currently required for application startup
# TODO: Make Redis optional with in-memory fallback
REDIS_URL=redis://127.0.0.1:6379

# ============================================================================
# OBJECT STORAGE (RustFS — S3-compatible, see docker-compose rustfs service)
# ============================================================================
# Provider: "local" (UPLOAD_DIR only) or "rustfs" (S3-compatible endpoint)
OBJECT_STORAGE_PROVIDER=rustfs
# API endpoint (host must match where the backend runs: localhost from host, rustfs:9000 from Docker)
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=crm-objects
OBJECT_STORAGE_ACCESS_KEY=rustfsadmin
OBJECT_STORAGE_SECRET_KEY=rustfsadmin

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level for the application
# Default: info
# Options: trace, debug, info, warn, error
#
# Recommendations:
#   Development: debug or trace
#   Production: info or warn
RUST_LOG=info

# Enable JSON-formatted logs (useful for log aggregation)
# Options: 0 (disabled), 1 (enabled)
# RUST_LOG_FORMAT=json

# ============================================================================
# MONITORING (Optional - for Prometheus integration)
# ============================================================================
# Prometheus metrics endpoint port
# Default: 9090
# Uncomment to enable metrics collection
# METRICS_PORT=9090

# ============================================================================
# SECURITY HEADERS (Optional)
# ============================================================================
# Enable strict security headers in production
# ENABLE_SECURITY_HEADERS=true

# Content Security Policy
# CSP_POLICY="default-src 'self'"

# ============================================================================
# RATE LIMITING (Built-in, configurable in code)
# ============================================================================
# Current limits (hardcoded, modify in code if needed):
#   Auth endpoints: 5 requests/minute
#   Upload endpoints: 10 requests/minute
#   General endpoints: 100 requests/minute

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
#
# [ ] JWT_SECRET is a strong random string (min 32 characters)
# [ ] CORS_ORIGIN is set to your actual frontend domain
# [ ] DATABASE_URL points to persistent storage
# [ ] UPLOAD_DIR has proper permissions and backups
# [ ] RUST_LOG is set to info or warn (not debug/trace)
# [ ] File size limits are appropriate for your use case
# [ ] Redis is properly configured and secured
# [ ] SSL/TLS is configured (use reverse proxy like nginx)
# [ ] Database backups are automated
# [ ] Monitoring is enabled (Prometheus + Grafana)
# [ ] Change default user passwords after first login
# [ ] Review and update dependencies regularly

# ============================================================================
# NOTES
# ============================================================================
# - Lines starting with # are comments
# - Empty lines are ignored
# - No spaces around = sign
# - Quotes are optional for values without spaces
# - This file should NOT be committed to version control
# - Add .env to .gitignore
