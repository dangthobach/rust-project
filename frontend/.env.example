# Neo CRM Frontend - Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Backend API base URL
# Default: http://localhost:3000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:3000

# WebSocket URL (for real-time notifications - currently disabled)
# Default: ws://localhost:3000
# Production: wss://api.yourdomain.com
# NOTE: WebSocket feature is currently disabled in backend
VITE_WS_URL=ws://localhost:3000

# ============================================================================
# APP CONFIGURATION
# ============================================================================
# Application name (displayed in UI)
VITE_APP_NAME=Neo CRM

# Application version
VITE_APP_VERSION=2.0.0

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Environment mode (affects error handling and logging)
# Options: development, production
# NODE_ENV=development

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
#
# [ ] VITE_API_URL points to production backend
# [ ] VITE_WS_URL uses wss:// (secure WebSocket)
# [ ] Remove any debug flags
# [ ] Test API connectivity
# [ ] Configure CORS on backend to allow your domain

# ============================================================================
# NOTES
# ============================================================================
# - All variables must be prefixed with VITE_ to be exposed to the frontend
# - Changes to .env require restarting the dev server
# - Production builds embed these values at build time
# - This file should NOT be committed to version control
# - Add .env to .gitignore
